generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model areas {
  id_area          Int              @id @default(autoincrement())
  name             String           @unique @db.VarChar(100)
  description      String
  id_administrator Int
  created_at       DateTime         @default(dbgenerated("CURRENT_DATE")) @db.Date
  status           status_area_type @default(active)
  positions        positions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model contracts {
  id_contract              Int                  @id @default(autoincrement())
  conditions               String
  contract_type            contract_type_enum
  status                   contract_status_enum @default(valid)
  start_date               DateTime             @db.Date
  end_date                 DateTime             @db.Date
  pdf_document             String
  id_employee              Int
  id_manager               Int
  created_at               DateTime             @db.Date
  public_id                String?
  expires_soon_notified_at DateTime?            @db.Date
}

model positions {
  id_position        Int                  @id @default(autoincrement())
  name               String
  base_salary        Float?
  description        String
  id_administrator   Int
  id_area            Int
  parent_position_id Int?
  created_at         DateTime             @default(dbgenerated("CURRENT_DATE")) @db.Date
  vacancies          Int
  status             status_position_type @default(active)
  areas              areas                @relation(fields: [id_area], references: [id_area], onDelete: Cascade, onUpdate: NoAction, map: "fk_area")
  positions          positions?           @relation("positionsTopositions", fields: [parent_position_id], references: [id_position], onUpdate: NoAction, map: "fk_parent_position")
  other_positions    positions[]          @relation("positionsTopositions")
}

enum contract_status_enum {
  valid
  expired
  renewed
  annulled
}

enum contract_type_enum {
  fixed_term_contract            @map("fixed-term-contract")
  indefinite_term_contract       @map("indefinite-term-contract")
  work_or_project_based_contract @map("work-or-project-based-contract")
  temporary_contract             @map("temporary-contract")
  apprenticeship_contract        @map("apprenticeship-contract")
  service_provision_contract     @map("service-provision-contract")
}

enum status_area_type {
  active
  inactive
}

enum status_position_type {
  active
  inactive
}
